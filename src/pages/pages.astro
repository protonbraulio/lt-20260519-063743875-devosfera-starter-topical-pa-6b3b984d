---
import generatedPages from "@/config/generated-pages.json";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

type GeneratedPageEntry = {
  title: string;
  href: string;
};

const pages = generatedPages as GeneratedPageEntry[];
const pageTitle = "Pages";
const pageDescription = `Generated pages published by ${SITE.title}.`;
---

<Layout title={`${pageTitle} | ${SITE.title}`} description={pageDescription}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-16">
    <article class="app-prose mx-auto max-w-3xl">
      <header class="mb-10">
        <p class="font-cartograph text-sm uppercase tracking-wide text-accent">
          Generated pages
        </p>
        <h1>{pageTitle}</h1>
        <p class="text-foreground/70">{pageDescription}</p>
      </header>
      {
        pages.length > 0 ? (
          <ul class="not-prose grid gap-3">
            {pages.map((page) => (
              <li>
                <a
                  href={page.href}
                  class="block rounded-2xl border border-border/25 bg-muted/10 p-5 transition-colors hover:border-accent/40 hover:bg-accent/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/45"
                >
                  <span class="font-semibold text-foreground">{page.title}</span>
                  <span class="mt-1 block font-cartograph text-sm text-foreground/55">
                    {page.href}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p>No generated pages are published yet.</p>
        )
      }
    </article>
  </main>
  <Footer />
</Layout>
